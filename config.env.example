# Copy this file to config.env and fill in your values

# GitHub personal access token (needs repo read access)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Anthropic API key for AI-powered PR summaries (skip if using AWS Bedrock)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# For AWS Bedrock (set CLAUDE_CODE_USE_BEDROCK=1 and AWS_REGION)
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-2

# Email recipients (comma-separated)
EMAIL_RECIPIENTS=you@example.com,team@example.com

# Email sender
EMAIL_FROM=repo-digest@yourdomain.com

# SMTP settings
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=25

# Default GitHub repo (owner/name format)
# Can be overridden at runtime with --repo flag
SGLANG_REPO=sgl-project/sglang

# Schedule: cron time in UTC (default: Monday 7AM IST = Monday 1:30 UTC)
# Only used when running in daemon mode
SCHEDULE_CRON=01:30
SCHEDULE_DAY=monday

# Number of top PRs to include in each section
TOP_N_PRS=40
